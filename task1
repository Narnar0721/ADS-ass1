public class Main {
    public static int findMin(int[] arr) {
        int min = arr[0];
        for (int num : arr) {
            if (num < min) min = num;
        }
        return min;
    }

    public static void main(String[] args) {
        int[] arr = {10, 1, 32, 3, 45};
        System.out.println(findMin(arr));
    }
}
